# find root dir
_dir="${BASH_SOURCE[0]}" && _dir="${_dir:-${(%):-%N}}" && _dir="${_dir%/bin/*}"

# libui.sh path
[[ "${1}" == '-?' ]] && printf "%s\n" "${LIBUI:-${_dir}/lib/sh/libui.sh}" && exit 0

if [[ 0 < ${#} && "${1:0:1}" != '-' ]]
then
  # load libui.sh
  source "${LIBUI:-${_dir}/lib/sh/libui.sh}" "${1}" "${@:2}"

  # execute script
  if [[ -f "${1}" ]]
  then
    source "${@}"
  else
    Tell -E -f "The provided command is not available. (${*})"
  fi
else
  # capture parameters for testing
  script=( "${BASH_SOURCE[0]:-${(%):-%x}}" )
  arg=( "${@}" )
  wd="${PWD}"
  [[ " ${*} " =~ .*\ -x\ n\ .* ]] && LIBUI_LEDGER='false' && LIBUI_TRACE='false' && LIBUI_STATS='false' # no log
  [[ " ${*} " =~ .*\ -x\ P\ .* ]] && LIBUI_PLAIN=true # plain ui
  [[ " ${*} " =~ .*\ -x\ T\ .* ]] && TERMINAL=false # no terminal

  # load libui.sh
  source "${LIBUI:-${_dir}/lib/sh/libui.sh}" "${0}" "${@}"

  # load mods
  LoadMod Libui

  # initialize UI
  Initialize

  # process actions
  _LibuiProcess
fi

Exit ${?}
