test_No_Term_Ask-z () {
  LibuiGetDisplayTestValues
  Ask -z 'Test question?' <<< ''
  LibuiPerformTest 'Tell "The answer is: %s" "${ANSWER}"'
  LibuiValidateTest ${?} 0 'The answer is: '
  return ${?}
}

# test setup
_Test_opt+='-x T '

return 0
