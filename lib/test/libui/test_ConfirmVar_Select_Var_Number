test_ConfirmVar_Select_Var_Number () {
  LibuiGetDisplayTestValues
  unset response
  testlist=( 'one' 'two' 'three' )
  TERMINAL=true LibuiPerformTest 'ConfirmVar -S testlist -q "Test question?" response <<< "2"; printf "%s\n" "${response}"'
  LibuiValidateTest ${?} 0 "${N}The possible responses are:${N}   1. one${N}   2. two${N}   3. three${N}${N}Test question? [] two"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
