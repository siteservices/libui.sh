test_ZV () {
  LibuiGetDisplayTestValues
  local zv
  ${ZSH} && ((${#ZSH_VERSION//[^\.]/} > 1)) && zv="${ZSH_VERSION%.*}" || zv="${ZSH_VERSION:-0}"; zv="${zv//.}"
  LibuiPerformTest 'Tell -- "${ZV}"'
  LibuiValidateTest ${?} 0 "${zv}"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
