test_ConfirmVar_Select_Value_Text () {
  LibuiGetDisplayTestValues
  unset response
  TERMINAL=true LibuiPerformTest 'ConfirmVar -s one -s two -s three -q "Test question?" response <<< "two"; printf "%s\n" "${response}"'
  LibuiValidateTest ${?} 0 "${N}The possible responses are:${N}   1. one${N}   2. two${N}   3. three${N}${N}Test question? [] two"
  return ${?}
}

 test setup
_Test_opt+='-x P '

return 0
