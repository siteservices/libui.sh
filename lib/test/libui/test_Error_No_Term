test_Error_No_Term () {
  LibuiGetDisplayTestValues
  _exitcleanup=false
  LibuiPerformTest 'Error "Test 1."'
  local tv=${?}
  _exitcleanup=true
  LibuiValidateTest "${tv}" 1 "ERROR: Test 1."
  return ${?}
}

# test setup
_Test_opt+='-x T '

return 0
