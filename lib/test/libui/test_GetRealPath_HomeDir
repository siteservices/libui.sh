test_GetRealPath_HomeDir () {
  LibuiGetDisplayTestValues
  local mp="${HOME}/.config/libui"
  local rp='~/.config/libui'
  GetRealPath rp
  LibuiPerformTest 'Tell -- "${rp}"'
  LibuiValidateTest ${?} 0 "${mp}"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
