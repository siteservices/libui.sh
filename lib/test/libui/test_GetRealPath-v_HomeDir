#
#####

test_GetRealPath-v_HomeDir () {
  LibuiGetDisplayTestValues
  local mp="${HOME}/non-exsiting"
  local rp='~/non-exsiting'
  GetRealPath -v rp
  LibuiPerformTest 'Tell -- "${rp}"'
  LibuiValidateTest ${?} 0 "${mp}"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
