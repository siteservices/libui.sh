#!/usr/bin/env libui
#####
#
# test_ConfirmVar_File_Select_Alt
#
#####

test_ConfirmVar_File_Select_Alt () {
  LibuiGetDisplayTestValues
  Action -W "touch ${TESTDIR}/listfile-1"
  Action -W "touch ${TESTDIR}/listfile\ 2"
  Action -W "mkdir -p ${TESTDIR}/listdir-1"
  Action -W "touch ${TESTDIR}/listdir-1/testfile\ 1"
  GetFileList -f testlist "${TESTDIR}/list*"
  unset response
  TERMINAL=true LibuiPerformTest 'ConfirmVar -f -S testlist -q "Test question?" -P "${TESTDIR}" response <<< "${TESTDIR}/listdir-1/testfile 1"; printf "%s\n" "${response}"'
  LibuiValidateTest ${?} 0 "${N}The possible responses are:${N}   1. listfile 2${N}   2. listfile-1${N}${N}Test question? [] ${TESTDIR}/listdir-1/testfile 1"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
