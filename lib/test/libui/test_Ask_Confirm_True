# test_Ask_Confirm_True
#
#####

test_Ask_Confirm_True () {
  LibuiGetDisplayTestValues
  Yes -e
  TERMINAL=true LibuiPerformTest 'Ask -C "Test Ask -C with Confirm true?"'
  local tv=${?}
  Yes -E
  LibuiValidateTest "${tv}" 0 'Test Ask -C with Confirm true? [yes] yes'
  return ${?}
}

# test setup
_Test_opt+='-x P -X C '

return 0
