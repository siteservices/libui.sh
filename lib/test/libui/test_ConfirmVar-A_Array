#!/usr/bin/env libui
#####
#
# test_ConfirmVar-A_Array
#
#####

test_ConfirmVar-A_Array () {
  LibuiGetDisplayTestValues
  testvar=( 'test' )
  _exitcleanup=false
  LibuiPerformTest 'ConfirmVar -A testvar'
  local tv=${?}
  _exitcleanup=true
  LibuiValidateTest "${tv}" 1 'ERROR: The variable "testvar" is not an associative array.'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
