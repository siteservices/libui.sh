test_Confirm_FMFLAG-C () {
  LibuiGetDisplayTestValues
  LibuiPerformTest 'Tell "Test confirm -C FMFLAGS: %s." "${FMFLAGS}"'
  LibuiValidateTest ${?} 0 'Test confirm -C FMFLAGS: -i.'
  return ${?}
}

# test setup
_Test_opt+='-x P -X C '

return 0
