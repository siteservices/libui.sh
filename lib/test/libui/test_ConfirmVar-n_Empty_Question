#!/usr/bin/env libui
#####
#
# test_ConfirmVar-n_Empty_Question
#
#####

test_ConfirmVar-n_Empty_Question () {
  LibuiGetDisplayTestValues
  unset response
  TERMINAL=true LibuiPerformTest 'ConfirmVar -q "Empty question?" -n response <<< "/tmp"'
  LibuiValidateTest ${?} 0 'Empty question? [] '
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
