test_Ask_Variable () {
  LibuiGetDisplayTestValues
  Yes -e
  TERMINAL=true Ask -d 'default variable' -n testvar 'Test Ask with testvar?'
  Yes -E
  LibuiPerformTest 'Tell "Test variable: ${testvar}."'
  LibuiValidateTest ${?} 0 'Test variable: default variable.'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
