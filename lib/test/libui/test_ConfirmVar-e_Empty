#!/usr/bin/env libui
#####
#
# test_ConfirmVar-e_Empty
#
#####

test_ConfirmVar-e_Empty () {
  LibuiGetDisplayTestValues
  testvar="${TESTDIR}/invalid-cvfile"
  _exitcleanup=false
  LibuiPerformTest 'ConfirmVar -e testvar'
  local tv=${?}
  _exitcleanup=true
  LibuiValidateTest "${tv}" 1 "ERROR: The path \"${TESTDIR}/invalid-cvfile\" does not exist. (testvar)"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
