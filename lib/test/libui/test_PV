test_PV () {
  LibuiGetDisplayTestValues
  local pv=true
  local zv
  ${ZSH} && ((${#ZSH_VERSION//[^\.]/} > 1)) && zv="${ZSH_VERSION%.*}" || zv="${ZSH_VERSION:-0}"; zv="${zv//.}"
  ${ZSH} && ((zv < 53)) && pv=false
  LibuiPerformTest 'Tell -- "${PV}"'
  LibuiValidateTest ${?} 0 "${pv}"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
