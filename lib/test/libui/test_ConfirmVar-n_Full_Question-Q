#!/usr/bin/env libui
#####
#
# test_ConfirmVar-n_Full_Question-Q
#
#####

test_ConfirmVar-n_Full_Question-Q () {
  LibuiGetDisplayTestValues
  response='/tmp'
  TERMINAL=true LibuiPerformTest 'ConfirmVar -Q "Full question?" -n response <<< "/tmp"'
  LibuiValidateTest ${?} 0 'Full question? [/tmp] '
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
