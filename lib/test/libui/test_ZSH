#!/usr/bin/env libui
#####
#
# test_ZSH
#
#####

test_ZSH () {
  LibuiGetDisplayTestValues
  LibuiPerformTest 'Tell -- "${ZSH}"'
  local tv=${?}
  if ${ZSH}
  then
    LibuiValidateTest "${tv}" 0 'true'
  else
    LibuiValidateTest "${tv}" 0 'false'
  fi
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
