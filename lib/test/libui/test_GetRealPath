#!/usr/bin/env libui
#####
#
# test_GetRealPath
#
#####

test_GetRealPath () {
  LibuiGetDisplayTestValues
  local mp="$(readlink /var 2> /dev/null)"; [[ -n "${mp}" ]] && mp="/${mp%/*}"
  local rp=file
  local td
  GetTmp td
  Action -W "touch ${td}/file"
  cd ${td}
  GetRealPath rp
  cd -
  LibuiPerformTest 'Tell -- "${rp}"'
  LibuiValidateTest ${?} 0 "${mp}${td}/file"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
