test_GetRealPath-v_CurrentDir () {
  LibuiGetDisplayTestValues
  local mp="${wd}/non-exsiting"
  local rp='./non-exsiting'
  GetRealPath -v rp
  LibuiPerformTest 'Tell -- "${rp}"'
  LibuiValidateTest ${?} 0 "${mp}"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
