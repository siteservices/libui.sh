test_AO () {
  LibuiGetDisplayTestValues
  LibuiPerformTest 'Tell -- "${AO}"'
  local tv=${?}
  if ${ZSH}
  then
    LibuiValidateTest "${tv}" 0 1
  else
    LibuiValidateTest "${tv}" 0 0
  fi
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
