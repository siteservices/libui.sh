#
#####

test_GetRealPath_d () {
  LibuiGetDisplayTestValues
  local mp="$(readlink /var 2> /dev/null)"; [[ -n "${mp}" ]] && mp="/${mp%/*}"
  local rp=file
  local td
  GetTmp td
  cd ${td}
  GetRealPath -P rp
  cd -
  LibuiPerformTest 'Tell -- "${rp}"'
  LibuiValidateTest ${?} 0 "${mp}${td}/file"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
