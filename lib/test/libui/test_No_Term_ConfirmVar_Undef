test_No_Term_ConfirmVar_Undef () {
  LibuiGetDisplayTestValues
  unset noterm
  LibuiPerformTest 'ConfirmVar noterm'
  LibuiValidateTest ${?} 1 'ERROR: The variable "noterm" is required but not defined.'
  return ${?}
}

# test setup
_Test_opt+='-x T '

return 0
