test_XC_Confirm_Action-q () {
  LibuiGetDisplayTestValues
  TERMINAL=true LibuiPerformTest 'Action -q "Confirm question?" "ls -d /tmp" <<< "yes"'
  LibuiValidateTest ${?} 0 '(Confirm) Confirm question? (y/n) [yes] /tmp'
  return ${?}
}

# test setup
_Test_opt+='-x P -X C '

return 0
