test_XY_Yes_No_Term_Action-Cq () {
  LibuiGetDisplayTestValues
  LibuiPerformTest 'Action -C -q "Yes question?" "ls -d /tmp"'
  LibuiValidateTest ${?} 0 "(Confirm) Yes question? (y/n) [yes] yes${N}/tmp"
  return ${?}
}

# test setup
_Test_opt+='-x T -X Y '

return 0
