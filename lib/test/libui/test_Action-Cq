#
#####

test_Action-Cq () {
  LibuiGetDisplayTestValues
  TERMINAL=true LibuiPerformTest 'Action -C -q "Verify question?" "ls -d /tmp" <<< "yes"'
  LibuiValidateTest ${?} 0 '(Confirm) Verify question? (y/n) [yes] /tmp'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
