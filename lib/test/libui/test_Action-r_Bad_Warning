test_Action-r_Bad_Warning () {
  LibuiGetDisplayTestValues
  retries=4
  LibuiPerformTest 'Action -r 3 -w 0.1 "RetryCountdown"'
  LibuiValidateTest ${?} 1 "Bad${N}Bad${N}Bad${N}WARNING: (Action) Failure while evaluating command. (RetryCountdown)"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
