test_ConfirmVar_Single_Select_Value () {
  LibuiGetDisplayTestValues
  unset response
  TERMINAL=true LibuiPerformTest 'ConfirmVar -s one -q "Test question?" response <<< ""; printf "%s\n" "${response}"'
  LibuiValidateTest ${?} 0 "${N}The possible responses are:${N}   1. one${N}${N}Test question? [one] one"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
