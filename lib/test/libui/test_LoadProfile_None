test_LoadProfile_None () {
  LibuiGetDisplayTestValues
  LibuiPerformTest 'Tell -- "${profile_data}"'
  LibuiValidateTest ${?} 0 ''
  return ${?}
}

# test setup
printf '%s\n' "profile_data='Profile data loaded.'" > "${TESTDIR}/test.profile"

# test setup
_Test_opt+='-x P '

return 0
