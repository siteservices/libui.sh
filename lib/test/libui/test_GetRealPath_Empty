#!/usr/bin/env libui
#####
#
# test_GetRealPath_Empty
#
#####

test_GetRealPath_Empty () {
  LibuiGetDisplayTestValues
  local rp
  local td
  GetTmp td
  cd ${td}
  _exitcleanup=false
  LibuiPerformTest 'GetRealPath rp'
  local tv=${?}
  _exitcleanup=true
  cd -
  LibuiValidateTest "${tv}" 1 "ERROR: (GetRealPath) No path provided. (rp)"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
