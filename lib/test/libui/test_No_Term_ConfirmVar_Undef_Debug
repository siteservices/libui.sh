#!/usr/bin/env libui
#####
#
# test_No_Term_ConfirmVar_Undef_Debug
#
#####

test_No_Term_ConfirmVar_Undef_Debug () {
  LibuiGetDisplayTestValues
  unset noterm
  local x=%{_xdb}
  _xdb=1
  LibuiPerformTest 'ConfirmVar noterm'
  local tv=${?}
  _xdb="${x}"
  LibuiValidateTest -r "${tv}" 1 'ERROR in .*: The variable "noterm" is required but not defined.'
  return ${?}
}

# test setup
_Test_opt+='-x T '

return 0
