test_Action-i () {
  LibuiGetDisplayTestValues
  TERMINAL=true LibuiPerformTest 'Action -i "Test info." "ls -d /tmp" 4>&1'
  LibuiValidateTest ${?} 0 "${TJBL}${TAction}Test info.${T}${TCEL}${TJBL}/tmp"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
