test_ConfirmVar_Dir_Select_Var_Number () {
  LibuiGetDisplayTestValues
  Action -W "mkdir -p ${TESTDIR}/listdir-1"
  Action -W "mkdir -p ${TESTDIR}/listdir\ 2"
  GetFileList -d testlist "${TESTDIR}/list*"
  unset response
  TERMINAL=true LibuiPerformTest 'ConfirmVar -d -S testlist -q "Test question?" -P "${TESTDIR}" response <<< "2"; printf "%s\n" "${response}"'
  LibuiValidateTest ${?} 0 "${N}The possible responses are:${N}   1. listdir 2${N}   2. listdir-1${N}${N}Test question? [] ${TESTDIR}/listdir-1"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
