#
#####

test_Ask_Select_Value_Number () {
  LibuiGetDisplayTestValues
  TERMINAL=true Ask -s one -s two -s three 'Test question?' <<< '3'
  LibuiPerformTest 'Tell "The answer is: %s" "${ANSWER}"'
  LibuiValidateTest ${?} 0 'The answer is: three'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
