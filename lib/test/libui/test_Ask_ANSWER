test_Ask_ANSWER () {
  LibuiGetDisplayTestValues
  Yes -e
  TERMINAL=true Ask -d 'default answer' -n testvar 'Test Ask with testvar?'
  Yes -E
  LibuiPerformTest 'Tell "Test variable: ${ANSWER}."'
  LibuiValidateTest ${?} 0 'Test variable: default answer.'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
