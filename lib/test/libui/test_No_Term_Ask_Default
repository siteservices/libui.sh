test_No_Term_Ask_Default () {
  LibuiGetDisplayTestValues
  Yes -e
  LibuiPerformTest 'Ask -d "default" "Test Ask with default?"'
  local tv=${?}
  Yes -E
  LibuiValidateTest "${tv}" 0 'Test Ask with default? [default] default'
  return ${?}
}

# test setup
_Test_opt+='-x T '

return 0
