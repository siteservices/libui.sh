test_Ask_Yes () {
  LibuiGetDisplayTestValues
  Yes -e
  TERMINAL=true LibuiPerformTest 'Ask "Test Ask command?"'
  local tv=${?}
  Yes -E
  LibuiValidateTest "${tv}" 0 'Test Ask command? [yes] yes'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
