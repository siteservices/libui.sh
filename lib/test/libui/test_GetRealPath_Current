#
#####

test_GetRealPath_Current () {
  LibuiGetDisplayTestValues
  local mp="$(readlink /var 2> /dev/null)"; [[ -n "${mp}" ]] && mp="/${mp%/*}"
  local rp
  local td
  GetTmp td
  cd ${td}
  GetRealPath rp .
  cd -
  LibuiPerformTest 'Tell -- "${rp}"'
  LibuiValidateTest ${?} 0 "${mp}${td}"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
