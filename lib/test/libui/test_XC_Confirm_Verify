test_XC_Confirm_Verify () {
  LibuiGetDisplayTestValues
  TERMINAL=true LibuiPerformTest 'Verify "Test verify?" <<< "yes"'
  LibuiValidateTest ${?} 0 'Test verify? (y/n) [yes] '
  return ${?}
}

# test setup
_Test_opt+='-x P -X C '

return 0
