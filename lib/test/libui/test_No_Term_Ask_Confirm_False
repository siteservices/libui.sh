test_No_Term_Ask_Confirm_False () {
  LibuiGetDisplayTestValues
  Yes -e
  LibuiPerformTest 'Ask -C "Test No Term Ask -C with Confirm false?"'
  local tv=${?}
  Yes -E
  LibuiValidateTest "${tv}" 0 ''
  return ${?}
}

# test setup
_Test_opt+='-x T '

return 0
