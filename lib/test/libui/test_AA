test_AA () {
  LibuiGetDisplayTestValues
  local bv="${BASH_VERSION//[^\.]/}" && ((${#bv} > 1)) && bv="${BASH_VERSION%.*}" || bv="${BASH_VERSION:-0}"; bv="${bv//.}"
  LibuiPerformTest 'Tell -- "${AA}"'
  local tv=${?}
  if ${ZSH} || ((40 <= bv))
  then
    LibuiValidateTest "${tv}" 0 'true'
  else
    LibuiValidateTest "${tv}" 0 'false'
  fi
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
