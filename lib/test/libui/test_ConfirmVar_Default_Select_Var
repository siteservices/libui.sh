#
#####

test_ConfirmVar_Default_Select_Var () {
  LibuiGetDisplayTestValues
  unset response
  testlist=( 'one' 'two' 'three' )
  TERMINAL=true LibuiPerformTest 'ConfirmVar -S testlist -q "Test question?" -D "three" response <<< ""; printf "%s\n" "${response}"'
  LibuiValidateTest ${?} 0 "${N}The possible responses are:${N}   1. one${N}   2. two${N}   3. three${N}${N}Test question? [three] three"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
