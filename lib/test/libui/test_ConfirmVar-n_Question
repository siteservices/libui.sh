#!/usr/bin/env libui
#####
#
# test_ConfirmVar-n_Question
#
#####

test_ConfirmVar-n_Question () {
  LibuiGetDisplayTestValues
  unset response
  TERMINAL=true ConfirmVar -q 'Test question?' -n response <<< '/tmp'
  LibuiPerformTest 'Tell "The value is: %s" "${response}"'
  LibuiValidateTest ${?} 0 'The value is: /tmp'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
