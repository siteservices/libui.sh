#!/usr/bin/env libui
#####
#
# test_GetRealPath_Bad
#
#####

test_GetRealPath_Bad () {
  LibuiGetDisplayTestValues
  local rp
  _exitcleanup=false
  LibuiPerformTest 'GetRealPath rp /badpath'
  local tv=${?}
  _exitcleanup=true
  LibuiValidateTest "${tv}" 1 "ERROR: (GetRealPath) Invalid path provided. (/badpath)"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
