#!/usr/bin/env libui
#####
#
# test_ConfirmVar_Undef
#
#####

test_ConfirmVar_Undef () {
  LibuiGetDisplayTestValues
  unset response
  _exitcleanup=false
  LibuiPerformTest 'ConfirmVar response'
  local tv=${?}
  _exitcleanup=true
  LibuiValidateTest "${tv}" 1 'ERROR: The variable "response" is required but not defined.'
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
