#!/usr/bin/env libui
#####
#
# test_No_Term_Ask
#
#####

test_No_Term_Ask () {
  LibuiGetDisplayTestValues
  _exitcleanup=false
  LibuiPerformTest 'Ask "Test Ask command?"'
  local tv=${?}
  _exitcleanup=true
  LibuiValidateTest "${tv}" 1 "ERROR: (Ask) Question asked without a terminal, no default, and a response required."
  return ${?}
}

# test setup
_Test_opt+='-x T '

return 0
