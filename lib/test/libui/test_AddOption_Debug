test_AddOption_Debug () {
  LibuiGetDisplayTestValues
  LoadMod Info
  LibuiPerformTest 'UsageInfo'
  LibuiValidateTest -r ${?} 2 '.*-X *XOption *- *XOptions, use -XH for details\. \(level: 2.*'
  return ${?}
}

# test setup
_Test_opt+='-x T -X 2 ' # no terminal

return 0
