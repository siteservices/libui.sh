test_ConfirmVar_File_Select_Value_Text () {
  LibuiGetDisplayTestValues
  Action -W "touch ${TESTDIR}/listfile-1"
  Action -W "touch ${TESTDIR}/listfile\ 2"
  unset response
  TERMINAL=true LibuiPerformTest 'ConfirmVar -f -s "${TESTDIR}/listfile-1" -s "${TESTDIR}/listfile 2" -q "Test question?" -P "${TESTDIR}" response <<< "listfile 2"; printf "%s\n" "${response}"'
  LibuiValidateTest ${?} 0 "${N}The possible responses are:${N}   1. listfile-1${N}   2. listfile 2${N}${N}Test question? [] ${TESTDIR}/listfile 2"
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
