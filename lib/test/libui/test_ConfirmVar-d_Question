test_ConfirmVar-d_Question () {
  LibuiGetDisplayTestValues
  unset response
  TERMINAL=true LibuiPerformTest "ConfirmVar -q 'Directory question?' -d response <<< '/tmp'"
  LibuiValidateTest ${?} 0 'Directory question? [] '
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
