#!/usr/bin/env libui
#####
#
# test_ConfirmVar-nz_Question
#
#####

test_ConfirmVar-nz_Question () {
  LibuiGetDisplayTestValues
  unset response
  TERMINAL=true ConfirmVar -q 'Test question?' -z -n response <<< ''
  LibuiPerformTest 'Tell "The value is: %s" "${response}"'
  LibuiValidateTest ${?} 0 'The value is: '
  return ${?}
}

# test setup
_Test_opt+='-x P '

return 0
