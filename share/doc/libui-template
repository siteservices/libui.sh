                                                                                                   # demo content
Trace 'Process files. (%s)' "${files[*]}"                                                          # demo content
GetFileList files                                                                                  # demo content
for file in "${files[@]}"                                                                          # demo content
do                                                                                                 # demo content
  printf 'File: %s' "${file}"                                                                      # demo content
  Action -q "Copy ${file}?" -i "Copying file... (${file})" "cp ${FMFLAGS} '${file}' '${tmpdir}'"   # demo content
done                                                                                               # demo content
((retval+=${?}))                                                                                   # demo content
                                                                                                   # demo content
ls -l "${tmpdir}"                                                                                  # demo content
                                                                                                   # demo content
